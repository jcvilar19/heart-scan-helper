# -----------------------------------------------------------------------------
# CardioScan — frontend environment variables
#
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
# Vite only exposes variables prefixed with `VITE_` to the browser bundle.
# -----------------------------------------------------------------------------

# Supabase (auth + storage). Anon key is safe to expose to the browser.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Same values, server-side. Used by Supabase Edge Functions / SSR.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Inference server (FastAPI in `inference_server/server.py`).
#
# Local dev (server running on your laptop):
#   VITE_PREDICT_API_URL=http://127.0.0.1:8000
# If you open the app via Vite’s Network URL (http://192.168.x.x:8080), the
# client auto-rewrites 127.0.0.1/localhost in this URL to that LAN IP for /health
# and /predict (see src/lib/predict-api-url.ts).
#
# Public dev / Lovable preview (ngrok tunnel — see scripts/dev-public.sh):
#   VITE_PREDICT_API_URL=https://your-subdomain.ngrok-free.app
#
# Production (Hugging Face Spaces — see scripts/deploy-space.sh + README §1):
#   VITE_PREDICT_API_URL=https://<your-handle>-cardio-scan-api.hf.space
# -----------------------------------------------------------------------------
VITE_PREDICT_API_URL=http://127.0.0.1:8000

# Optional: force the mock classifier (no network call). Useful for UI work
# without a running model server.
# VITE_USE_MOCK_PREDICTION=true
