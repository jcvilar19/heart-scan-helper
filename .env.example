# Copy this file to ".env" in the project root and fill in real values.
# Dashboard: https://supabase.com/dashboard → your project → Settings → API

# Client (Vite exposes only variables prefixed with VITE_)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here

# Same values for SSR / server (TanStack Start reads process.env)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here

# Optional: only if you use server-side admin routes
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: Python inference API
VITE_PREDICT_API_URL=http://localhost:8000
